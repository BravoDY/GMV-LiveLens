# GMV-LiveLens 环境变量配置模板
# 复制为 .env 后修改，启动脚本会自动加载

# === 应用环境 ===
# development: 本地开发；production: 公网/生产部署
GMV_APP_ENV=development

# === API 安全 ===
# 公网部署前必须设置强随机 token，并将 GMV_REQUIRE_API_TOKEN 改为 true。
# production 环境会自动要求高风险写接口携带请求头 X-API-Token。
# 受保护接口包括：settings、scheduler start/pause、tasks 写操作、shops init/bind、edge/platform 控制等。
GMV_API_TOKEN=change-me-before-public-deploy
GMV_REQUIRE_API_TOKEN=false

# === CORS 跨域 ===
# A 路线默认由后端托管前端；如未来前后端分域部署，请改成你的真实域名正则
GMV_CORS_ORIGIN_REGEX=https?://(localhost|127\.0\.0\.1)(:\d+)?

# === 调试接口 ===
# 生产环境建议关闭
GMV_DEBUG_API_ENABLED=true

# === OCR 引擎 ===
# 可选值: auto (自动选择可用引擎) | rapidocr | ddddocr | paddleocr
# 默认: auto
GMV_OCR_ENGINE=auto

# === 截图清理策略 ===
# 采集截图保留天数，超期自动删除
# 默认: 1 (天)
GMV_SCREENSHOT_MAX_AGE_DAYS=1

# === 页面巡检频率 ===
# 巡检最小间隔 (秒)，用于页面截图自动巡检
# 默认: 180 (3分钟)
GMV_PREVIEW_MIN_INTERVAL_SECONDS=180

# 巡检最大间隔 (秒)
# 默认: 480 (8分钟)
GMV_PREVIEW_MAX_INTERVAL_SECONDS=480

# === 页面巡检截图最大宽度 (像素) ===
# 缩小巡检截图以节省磁盘空间
# 默认: 720
GMV_PREVIEW_MAX_WIDTH=720

# === MySQL 历史数据源（看板周期查询） ===
# 用于 dashboard-test 页面中 "全" / "一裙" 等周期数据集的同比分析
# 目标表: descente_al店铺整体取数源 (字段: 平台, 统计日期, 支付金额)
#
# 安全提醒：密码不应明文保存在 .env 文件中。
# 推荐方式：
#   1. 开发环境：在 .env 中填写密码（已在 .gitignore 中排除，不会提交到 Git）
#   2. 生产环境：使用 Windows 凭据管理器，或独立密钥文件
#   3. 多机部署：在每台机器上独立设置 .env，切勿将含密码的 .env 复制到共享目录
MYSQL_HOST=10.128.64.96
MYSQL_PORT=3306
MYSQL_USER=user_od_ecbi
MYSQL_PASSWORD=
MYSQL_DATABASE=od_ecbi
MYSQL_SOURCE_TABLE=descente_al店铺整体取数源
