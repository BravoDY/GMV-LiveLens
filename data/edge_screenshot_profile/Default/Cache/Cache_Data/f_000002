async function refreshRemoteHealth() {
  const health = await api("/api/remote-edge/health");
  const el = $("remoteHealth");
  if (!el) return;
  el.innerHTML = `
    <div>调试端口：${health.debug_available ? "已开启" : "未开启"}，连接：${health.connected ? "已连接" : "未连接"}</div>
    <div>页面：${health.visible_pages}/${health.total_pages}</div>
    <div>命令：${escapeHtml(health.edge_command || "-")}</div>
    <div>错误：${escapeHtml(health.last_error || "-")}</div>
  `;
}

async function startRemoteEdge() {
  const button = $("startRemoteEdge");
  button.disabled = true;
  button.textContent = "启动中...";
  showMessage("正在用调试命令启动真实 Edge。若失败，请先关闭所有普通 Edge 后再点一次。");
  try {
    await api("/api/remote-edge/start", { method: "POST" });
    await refreshRemoteHealth();
    await refreshRemotePages();
    showMessage("真实 Edge 调试已尝试启动。请在打开的真实 Edge 中进入目标页面，然后刷新真实 Edge 页面列表。");
  } finally {
    button.disabled = false;
    button.textContent = "启动真实 Edge 调试";
  }
}

async function openRemotePage() {
  const button = $("openRemotePage");
  const input = $("remoteUrl");
  const url = input?.value.trim();
  if (!url) {
    showMessage("请先输入要打开的真实 Edge 页面 URL", true);
    return;
  }
  button.disabled = true;
  button.textContent = "打开中...";
  showMessage("正在真实 Edge 调试窗口中打开新标签页。同一个调试 Edge 可以反复打开多个页面。");
  try {
    const page = await api("/api/remote-edge/open", { method: "POST", body: JSON.stringify({ url }) });
    await refreshRemotePages(page.page_id);
    showMessage("真实 Edge 页面已打开并已加入页面列表。每个店铺可以重复打开一次，再分别标定保存任务。");
  } finally {
    button.disabled = false;
    button.textContent = "打开真实 Edge 页面";
  }
}

async function refreshRemotePages(preferredPageId = "") {
  const pages = await api("/api/remote-edge/pages");
  const select = $("remotePageSelect");
  if (!select) return;
  select.innerHTML =
    pages
      .map((page) => `<option value="${page.page_id}" data-url="${escapeHtml(page.url)}" data-title="${escapeHtml(page.title)}">${escapeHtml(page.title || page.url)} (${page.page_id})</option>`)
      .join("") || `<option value="">暂无真实 Edge 页面</option>`;
  if (preferredPageId && pages.some((page) => page.page_id === preferredPageId)) {
    select.value = preferredPageId;
  } else if (pages.length) {
    select.value = pages[0].page_id;
  }
  await refreshRemoteHealth();
  showMessage(`真实 Edge 页面 ${pages.length} 个`);
}

async function previewRemotePage() {
  const pageId = $("remotePageSelect")?.value;
  if (!pageId) {
    showMessage("请先选择真实 Edge 页面", true);
    return;
  }
  const preview = await api(`/api/remote-edge/${pageId}/preview`, { method: "POST" });
  state.preview = preview;
  state.selection = null;
  state.currentPreviewSource = { capture_mode: "remote_edge", page_id: pageId, page_url: preview.page.url, page_title: preview.page.title };
  $("captureMode").value = "remote_edge";
  renderPreviewImage(preview);
  showMessage(`真实 Edge 页面预览已生成：${preview.width}x${preview.height}`);
}

async function reloadRemotePage() {
  const pageId = $("remotePageSelect")?.value;
  if (!pageId) {
    showMessage("请先选择真实 Edge 页面", true);
    return;
  }
  await api(`/api/remote-edge/${pageId}/reload`, { method: "POST" });
  await refreshRemotePages(pageId);
  showMessage("真实 Edge 页面已重载");
}

