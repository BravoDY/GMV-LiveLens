    if (!target) return;
    button = document.createElement("button");
    button.id = "schedulerToggle";
    button.className = "scheduler-button";
    button.type = "button";
    button.textContent = "启动采集";
    target.prepend(button);
  }
  button.addEventListener("click", () => toggleScheduler().catch((err) => alert(`调度操作失败：${parseApiError(err)}`)));
  refreshSchedulerStatus().catch(() => {});
}

async function refreshSchedulerStatus() {
  const status = await api("/api/scheduler");
  const button = $("schedulerToggle");
  if (!button) return status;
  button.dataset.running = status.running ? "1" : "0";
  button.textContent = status.running ? "暂停采集" : "启动采集";
  button.classList.toggle("active", status.running);
  return status;
}

async function toggleScheduler() {
  const button = $("schedulerToggle");
  const running = button?.dataset.running === "1";
  await api(running ? "/api/scheduler/pause" : "/api/scheduler/start", { method: "POST" });
  await refreshSchedulerStatus();
}

