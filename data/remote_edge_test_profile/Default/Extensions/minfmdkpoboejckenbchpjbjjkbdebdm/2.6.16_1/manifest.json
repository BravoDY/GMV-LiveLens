{
   "action": {
      "default_icon": {
         "48": "extIcons/action_48.png"
      },
      "default_title": "Open DeepSider"
   },
   "background": {
      "service_worker": "serviceworker.js"
   },
   "content_security_policy": {
      "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'; connect-src 'self' https://* http://*;"
   },
   "default_locale": "en",
   "description": "__MSG_ext_desc__",
   "externally_connectable": {
      "matches": [ "https://*.deepsider.ai/*", "https://*.deepsider.net/*", "https://*.deepsider.me/*", "https://*.deepsider.pro/*", "https://*.deepsider.app/*", "https://*.deepsider.online/*", "http://localhost:8080/*" ]
   },
   "icons": {
      "128": "extIcons/icon_128.png",
      "16": "extIcons/icon_16.png",
      "32": "extIcons/icon_32.png",
      "48": "extIcons/icon_48.png"
   },
   "key": "",
   "manifest_version": 3,
   "name": "__MSG_ext_edge_title__",
   "optional_host_permissions": [ "\u003Call_urls>" ],
   "optional_permissions": [ "tabs" ],
   "permissions": [ "sidePanel", "storage", "scripting" ],
   "side_panel": {
      "default_path": "sidePanel.html"
   },
   "update_url": "https://edge.microsoft.com/extensionwebstorebase/v1/crx",
   "version": "2.6.16",
   "web_accessible_resources": [ {
      "matches": [ "\u003Call_urls>" ],
      "resources": [ "*" ]
   } ]
}
