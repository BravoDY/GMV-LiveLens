{
   "background": {
      "page": "background.html"
   },
   "browser_action": {
      "default_icon": {
         "128": "icons/icon-128.png",
         "16": "icons/icon-16.png",
         "19": "icons/icon-19.png",
         "38": "icons/icon-38.png",
         "64": "icons/icon-64.png"
      },
      "default_popup": "popup.html",
      "default_title": "店透视(极速版)"
   },
   "content_scripts": [ {
      "all_frames": true,
      "js": [ "source/jquery.js", "source/Moment/index.js", "script/content_script.js" ],
      "matches": [ "*://*/*" ],
      "run_at": "document_end"
   } ],
   "content_security_policy": "script-src 'self' 'unsafe-eval'; object-src 'self'",
   "description": "专业的淘宝天猫、拼多多、京东、抖音等平台的卖家运营工具，包括生意参谋、直通车和搜索详情等功能的指数转换、数据分析导出等…",
   "homepage_url": "https://diantoushi.com",
   "icons": {
      "128": "icons/icon-128.png",
      "16": "icons/icon-16.png",
      "19": "icons/icon-19.png",
      "38": "icons/icon-38.png",
      "64": "icons/icon-64.png"
   },
   "key": "",
   "manifest_version": 2,
   "name": "店透视(极速版)",
   "options_ui": {
      "page": "popup.html"
   },
   "permissions": [ "*://*/*", "tabs", "activeTab", "storage", "cookies", "webRequest", "contextMenus", "notifications", "unlimitedStorage", "webRequestBlocking" ],
   "short_name": "店透视(极速版)",
   "update_url": "https://edge.microsoft.com/extensionwebstorebase/v1/crx",
   "version": "3.6.1",
   "web_accessible_resources": [ "source/*", "script/*" ]
}
